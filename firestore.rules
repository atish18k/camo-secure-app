rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helpers
    // -----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -----------------------------------------------------------------------
    // Users
    // -----------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create, update: if isOwner(userId);

      // ---------------------------------------------------------------------
      // Security
      // ---------------------------------------------------------------------

      match /security/{docId} {
        allow read: if isSignedIn();

        allow create, update: if isOwner(userId);

        allow delete: if false;
      }

      // ---------------------------------------------------------------------
      // Trusted Devices
      // ---------------------------------------------------------------------

      match /devices/{deviceId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId)
          || (
            isSignedIn()
            && request.query.limit != null
            && request.query.limit <= 1
            && resource.data.status == 'approved'
          );
        allow create, update, delete: if false;
      }

      // Client may create one deterministic pending request per device.
      // Approval remains server-only through the privileged callable.
      match /deviceRegistrationRequests/{requestId} {
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'schemaVersion', 'requestId', 'userId', 'deviceId',
            'publicKey', 'keyVersion', 'platform', 'status', 'requestedAt'
          ])
          && request.resource.data.schemaVersion == 1
          && request.resource.data.requestId == requestId
          && request.resource.data.userId == userId
          && request.resource.data.deviceId is string
          && request.resource.data.deviceId.size() > 0
          && request.resource.data.deviceId.size() <= 128
          && request.resource.data.publicKey is string
          && request.resource.data.publicKey.size() == 44
          && request.resource.data.keyVersion is int
          && request.resource.data.keyVersion > 0
          && request.resource.data.platform is string
          && request.resource.data.platform.size() > 0
          && request.resource.data.platform.size() <= 64
          && request.resource.data.status == 'pending'
          && request.resource.data.requestedAt is string
          && request.resource.data.requestedAt.size() >= 20
          && request.resource.data.requestedAt.size() <= 35;
        allow update: if isOwner(userId)
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
          && request.resource.data.requestId == resource.data.requestId
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.deviceId == resource.data.deviceId
          && request.resource.data.publicKey == resource.data.publicKey
          && request.resource.data.keyVersion == resource.data.keyVersion
          && request.resource.data.platform == resource.data.platform
          && request.resource.data
              .diff(resource.data)
              .affectedKeys()
              .hasOnly(['requestedAt'])
          && request.resource.data.requestedAt is string
          && request.resource.data.requestedAt.size() >= 20
          && request.resource.data.requestedAt.size() <= 35;
        allow get, list, delete: if false;
      }
    }

    // -----------------------------------------------------------------------
    // Pairings ΓÇö Existing Behavior Preserved
    // -----------------------------------------------------------------------

    match /pairings/{pairingId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participantUserIds;
      allow create, update, delete: if false;
    }

  }
}